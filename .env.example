# GEMINI_API_KEY: requis pour les appels à l'API Gemini.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MONGODB_URI: URI de connexion à MongoDB (Railway plugin "MongoDB" ou MongoDB Atlas).
# Exemple Atlas : mongodb+srv://user:password@cluster.mongodb.net/bac-ia
MONGODB_URI="mongodb://localhost:27017/bac-ia"

# JWT_SECRET: chaîne secrète utilisée pour signer les jetons de connexion.
# Générer une valeur aléatoire robuste, par exemple avec:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-with-a-long-random-string"

# PORT: fourni automatiquement par Railway en production. En local, 3000 par défaut.
PORT=3000
